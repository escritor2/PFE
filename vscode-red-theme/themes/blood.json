    "widget.shadow": "#000000"
  },
  "tokenColors": [
    {
      "settings": {
        "foreground": "#ff3333",
        "background": "#0d0000"
      }
    },
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#800000",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier",
        "control.flow",
        "control.structure"
      ],
      "settings": {
        "foreground": "#ff0000",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "constant.other.key",
        "string.quoted",
        "string.template",
        "string.regexp",
        "punctuation.definition.string.begin",
        "punctuation.definition.string.end",
        "markup.underline.link",
        "markup.bold"
      ],
      "settings": {
        "foreground": "#ff6666"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "number",
        "float",
        "integer",
        "hex",
        "binary"
      ],
      "settings": {
        "foreground": "#ff5555"
      }
    },
    {
      "scope": [
        "constant",
        "variable.language",
        "support.constant",
        "string.escape"
      ],
      "settings": {
        "foreground": "#ff8888"
      }
    },
    {
      "scope": [
        "function",
        "entity.name.function",
        "support.function",
        "declaration",
        "meta.function-call",
        "variable.function",
        "meta.function"
      ],
      "settings": {
        "foreground": "#ff4444",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "type",
        "entity.name.type",
        "support.type",
        "class",
        "struct",
        "enum",
        "interface",
        "builtin"
      ],
      "settings": {
        "foreground": "#ffaaaa"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.constant",
        "variable.other.property",
        "variable.parameter",
        "meta.definition.variable.name"
      ],
      "settings": {
        "foreground": "#ffcccc"
      }
    },
    {
      "scope": [
        "operator",
        "punctuation",
        "delimiter"
      ],
      "settings": {
        "foreground": "#ff7777"
      }
    },
    {
      "scope": [
        "tag",
        "entity.name.tag",
        "markup.heading",
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#ff0000",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "attribute-name",
        "attribute.name"
      ],
      "settings": {
        "foreground": "#cc0000"
      }
    },
    {
      "scope": [
        "variable.language",
        "variable.predefined"
      ],
      "settings": {
        "foreground": "#ffaaaa"
      }
    },
    {
      "scope": [
        "meta.embedded",
        "source"
      ],
      "settings": {
        "foreground": "#ff3333"
      }
    },
    {
      "scope": [
        "punctuation.definition.directive",
        "punctuation.definition.entity"
      ],
      "settings": {
        "foreground": "#ff9999"
      }
    },
    {
      "scope": [
        "markup.deleted",
        "deletion",
        "error"
      ],
      "settings": {
        "foreground": "#ff0000",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "markup.inserted",
        "insertion"
      ],
      "settings": {
        "foreground": "#ff6666"
      }
    },
    {
      "scope": [
        "markup.changed",
        "change"
      ],
      "settings": {
        "foreground": "#ff4444"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#ff0000",
        "background": "#330000"
      }
    },
    {
      "scope": [
        "meta.property-name",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#ff6666"
      }
    },
    {
      "scope": [
        "meta.brace",
        "punctuation.section"
      ],
      "settings": {
        "foreground": "#ff9999"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.class",
        "entity.other.attribute-name.id"
      ],
      "settings": {
        "foreground": "#ff8888",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.bold",
        "markup.italic",
        "markup.underline"
      ],
      "settings": {
        "foreground": "#ff0000"
      }
    },
    {
      "scope": [
        "source.json",
        "source.ini",
        "source.properties"
      ],
      "settings": {
        "foreground": "#ff3333"
      }
    },
    {
      "scope": [
        "support.type.property-name.json",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#ffcccc"
      }
    },
    {
      "scope": [
        "string.quoted.double.json",
        "string.quoted.single.json"
      ],
      "settings": {
        "foreground": "#ff6666"
      }
    },
    {
      "scope": [
        "entity.name.type.instance"
      ],
      "settings": {
        "foreground": "#ffaaaa"
      }
    }
  ]
}
